{
  "Cors": {
    "AllowedOrigins": [
      "https://labimacademy.vercel.app"
    ]
  },
  "CookieAuth": {
    "Secure": true,
    "SameSite": "Lax"
  },
  "Security": {
    "RequirePaymentCsrf": true,
    "ExposeTokenInLoginResponse": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "TrustProxyNetwork": true
  }
}
